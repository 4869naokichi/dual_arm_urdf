    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <inertia ixx="0.013" iyy="0.013" izz="0.0004" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="torso_fixed" type="fixed">
    <parent link="waist_link"/>
    <child link="torso_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
  </joint>
  <link name="neck_pan_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.0285 0.0465 0.034"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.0285 0.0465 0.034"/></geometry>
    </collision>
    <inertial>

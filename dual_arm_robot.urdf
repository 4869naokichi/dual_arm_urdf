<?xml version="1.0"?>
<robot name="dual_arm_robot">

  <material name="black">  <color rgba="0.24 0.24 0.24 1.0"/></material>
  <material name="green">  <color rgba="0.05 0.65 0.25 1.0"/></material>
  <material name="gray">   <color rgba="0.55 0.55 0.55 1.0"/></material>
  <material name="silver"> <color rgba="0.80 0.80 0.82 1.0"/></material>
  <material name="orange"> <color rgba="0.95 0.55 0.10 1.0"/></material>
  <material name="blue">   <color rgba="0.10 0.30 0.85 1.0"/></material>

  <link name="base_footprint"/>
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/base_link.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/base_link.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.013683" iyy="0.0137122" izz="0.00255217" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="base_footprint_to_base" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="torso_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/torso_link.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/torso_link.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="1.8"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0163086" iyy="0.0133106" izz="0.00526875" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="waist_joint" type="revolute">
    <parent link="base_link"/>
    <child link="torso_link"/>
    <origin xyz="0 0 0.2615" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3" upper="3" effort="10" velocity="2"/>
  </joint>
  <link name="neck_pan_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/neck_pan_link.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/neck_pan_link.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="2.45017e-05" iyy="2.75391e-05" izz="3.30001e-05" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="neck_pan_joint" type="revolute">
    <parent link="torso_link"/>
    <child link="neck_pan_link"/>
    <origin xyz="0 0 0.2805" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2" upper="2" effort="3" velocity="3"/>
  </joint>
  <link name="neck_tilt_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/neck_tilt_link.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/neck_tilt_link.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="4.04167e-05" iyy="1.72417e-05" izz="4.72417e-05" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="neck_tilt_joint" type="revolute">
    <parent link="neck_pan_link"/>
    <child link="neck_tilt_link"/>
    <origin xyz="0.024 0 0.0195" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1" upper="1" effort="3" velocity="3"/>
  </joint>
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/camera_link.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/camera_link.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="3.63542e-05" iyy="5.20833e-06" izz="3.63542e-05" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="camera_fixed" type="fixed">
    <parent link="neck_tilt_link"/>
    <child link="camera_link"/>
    <origin xyz="0.05625 0 0" rpy="0 0 0"/>
  </joint>
  <link name="camera_optical_frame"/>
  <joint name="camera_optical_fixed" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>


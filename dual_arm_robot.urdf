      <inertia ixx="3.63542e-05" iyy="5.20833e-06" izz="3.63542e-05" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="camera_fixed" type="fixed">
    <parent link="neck_tilt_link"/>
    <child link="camera_link"/>
    <origin xyz="0.05195 0 0" rpy="0 0 0"/>
  </joint>
  <link name="camera_optical_frame"/>
